# ServEase Mobile runtime configuration
# Copy this file to ".env" and replace placeholder values.

# Backend API base URL (NestJS gateway)
# iOS simulator / web: http://localhost:5000
# Android emulator:     http://10.0.2.2:5000
EXPO_PUBLIC_API_URL=http://localhost:5000

# HTTP timeout for backend API requests (milliseconds)
EXPO_PUBLIC_API_TIMEOUT_MS=15000
